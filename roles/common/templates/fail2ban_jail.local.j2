# Fail2ban configuration - Generated by Ansible
[DEFAULT]
bantime = {{ fail2ban_bantime | default(3600) }}
findtime = {{ fail2ban_findtime | default(600) }}
maxretry = {{ fail2ban_maxretry | default(3) }}
backend = auto
ignoreip = {{ fail2ban_ignoreip | join(' ') }}

[sshd]
enabled = true
port = {{ ssh_port | default('2222') }}
filter = sshd
logpath = {{ fail2ban_logpath | default('/var/log/auth.log') }}
maxretry = {{ fail2ban_maxretry | default(3) }}

[sshd-ddos]
enabled = true
port = {{ ssh_port | default('2222') }}
filter = sshd-ddos
logpath = {{ fail2ban_logpath | default('/var/log/auth.log') }}

[recidive]
enabled = true
filter = recidive
logpath = /var/log/fail2ban.log
bantime = 86400
findtime = 86400
maxretry = 5
