# SSH Configuration - Hardened
# Generated by Ansible

# Network
Port {{ ssh_port | default('2222') }}
AddressFamily {{ 'inet' if ipv6_disable | default(true) else 'any' }}
ListenAddress 0.0.0.0

# Authentication
PermitRootLogin {{ ssh_permit_root_login | default('no') }}
PasswordAuthentication {{ ssh_password_authentication | default('no') }}
PubkeyAuthentication {{ ssh_pubkey_authentication | default('yes') }}
PermitEmptyPasswords {{ ssh_permit_empty_passwords | default('no') }}
ChallengeResponseAuthentication no
KerberosAuthentication no
GSSAPIAuthentication no

# Security
X11Forwarding {{ ssh_x11_forwarding | default('no') }}
MaxAuthTries {{ ssh_max_auth_tries | default(3) }}
MaxSessions 5
ClientAliveInterval {{ ssh_client_alive_interval | default(300) }}
ClientAliveCountMax {{ ssh_client_alive_count_max | default(2) }}
LoginGraceTime {{ ssh_login_grace_time | default(60) }}
PermitUserEnvironment no
Compression no
UseDNS no

# Allow/Deny Users/Groups
{% if ssh_allow_users | default([]) | length > 0 %}
AllowUsers {{ ssh_allow_users | join(' ') }}
{% endif %}
{% if ssh_allow_groups | default([]) | length > 0 %}
AllowGroups {{ ssh_allow_groups | join(' ') }}
{% endif %}
{% if ssh_deny_users | default([]) | length > 0 %}
DenyUsers {{ ssh_deny_users | join(' ') }}
{% endif %}
{% if ssh_deny_groups | default([]) | length > 0 %}
DenyGroups {{ ssh_deny_groups | join(' ') }}
{% endif %}

# Logging
SyslogFacility AUTH
LogLevel VERBOSE

# Subsystems
Subsystem sftp /usr/lib/openssh/sftp-server

# Banner
Banner /etc/issue.net

# Other hardening
UsePAM yes
PrintMotd no
PrintLastLog yes
TCPKeepAlive yes
PermitTunnel no
AllowAgentForwarding no
AllowTcpForwarding no
GatewayPorts no
