[Unit]
Description={{ app_name }} Node.js application
After=network.target

[Service]
Type=simple
User={{ app_user }}
WorkingDirectory={{ app_base_dir }}/{{ app_name }}
ExecStart=/usr/bin/node {{ app_base_dir }}/{{ app_name }}/app.js
Restart=on-failure
Environment=NODE_ENV=production
Environment=PORT={{ app_port }}

[Install]
WantedBy=multi-user.target
